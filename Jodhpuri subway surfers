# Audio Manager for Rajasthani themed music
class AudioManager:
    def __init__(self):
        self.bg_music_playing = False
        self.music_volume = 0.5
        self.sound_effects_volume = 0.7
        self.music_enabled = True
        self.sound_effects_enabled = True
        
    def generate_rajasthani_rap_beat(self):
        """
        Generate a simple Rajasthani-themed beat using synthesized sounds.
        This is a fallback if no audio file exists.
        """
        # Create a simple "dhol" drum pattern
        frequency = 100  # Bass drum frequency
        duration = 500  # milliseconds
        sample_rate = 22050
        frames = int(sample_rate * duration / 1000)
        
        # Generate a simple sine wave
        import math
        arr = []
        for i in range(frames):
            # Create a decaying beat pattern
            amp = int(32767 * (1 - i / frames) * 0.3)
            val = int(amp * math.sin(2 * math.pi * frequency * i / sample_rate))
            arr.append(val & 0xffff)
        
        return arr
    
    def play_background_music(self):
        """Play background Rajasthani rap music"""
        if not self.music_enabled:
            return
            
        try:
            # Try to load a music file if it exists
            music_files = ["rajasthani_rap.mp3", "background.mp3", "rajasthani.mp3"]
            for music_file in music_files:
                if os.path.exists(music_file):
                    mixer.music.load(music_file)
                    mixer.music.set_volume(self.music_volume)
                    mixer.music.play(-1)  # Loop infinitely
                    self.bg_music_playing = True
                    return
            
            # If no file found, create a simple beep pattern
            print("No music file found. Using synthesized background audio.")
            self.create_synthetic_music()
            
        except Exception as e:
            print(f"Audio not available: {e}")
    
    def create_synthetic_music(self):
        """Create a simple synthesized music pattern if no file is available"""
        # This creates a basic drum pattern sound
        sample_rate = 22050
        duration = 2  # seconds
        
        # Create a simple pattern
        try:
            import math
            frames = sample_rate * duration
            arr = []
            
            for i in range(frames):
                # Create a simple pattern with different frequencies
                t = i / sample_rate
                beat_time = int(t) % 4
                
                # Drum pattern
                if 0 <= beat_time < 1:
                    freq = 150
                elif 1 <= beat_time < 2:
                    freq = 0
                elif 2 <= beat_time < 3:
                    freq = 150
                else:
                    freq = 100
                
                amp = 5000
                if freq > 0:
                    val = int(amp * math.sin(2 * math.pi * freq * i / sample_rate))
                else:
                    val = 0
                    
                arr.append(val & 0xffff)
            
            sound = pygame.sndarray.make_sound(arr)
            sound.set_volume(self.music_volume)
            sound.play(-1)
            self.bg_music_playing = True
        except:
            pass
    
    def stop_music(self):
        """Stop background music"""
        try:
            mixer.music.stop()
            self.bg_music_playing = False
        except:
            pass
    
    def toggle_music(self):
        """Toggle music on/off"""
        self.music_enabled = not self.music_enabled
        if self.music_enabled:
            self.play_background_music()
        else:
            self.stop_music()
    
    def play_coin_sound(self):
        """Play coin collection sound"""
        if not self.sound_effects_enabled:
            return
        try:
            # Simple beep for coin collection
            sample_rate = 22050
            duration = 100  # milliseconds
            frames = int(sample_rate * duration / 1000)
            
            import math
            arr = []
            for i in range(frames):
                freq = 800 + (i / frames) * 200  # Ascending tone
                amp = int(32767 * (1 - i / frames) * 0.3)
                val = int(amp * math.sin(2 * math.pi * freq * i / sample_rate))
                arr.append(val & 0xffff)
            
            sound = pygame.sndarray.make_sound(arr)
            sound.set_volume(self.sound_effects_volume)
            sound.play()
        except:
            pass
    
    def play_hit_sound(self):
        """Play collision/hit sound"""
        if not self.sound_effects_enabled:
            return
        try:
            sample_rate = 22050
            duration = 150
            frames = int(sample_rate * duration / 1000)
            
            import math
            arr = []
            for i in range(frames):
                freq = 300 - (i / frames) * 100  # Descending tone
                amp = int(32767 * (1 - i / frames) * 0.4)
                val = int(amp * math.sin(2 * math.pi * freq * i / sample_rate))
                arr.append(val & 0xffff)
            
            sound = pygame.sndarray.make_sound(arr)
            sound.set_volume(self.sound_effects_volume)
            sound.play()
        except:
            pass
    
    def play_powerup_sound(self):
        """Play power-up collection sound"""
        if not self.sound_effects_enabled:
            return
        try:
            sample_rate = 22050
            duration = 200
            frames = int(sample_rate * duration / 1000)
            
            import math
            arr = []
            for i in range(frames):
                t = i / sample_rate
                freq = 600 + 200 * (1 + math.sin(2 * math.pi * 4 * t)) / 2
                amp = int(32767 * (1 - i / frames) * 0.3)
                val = int(amp * math.sin(2 * math.pi * freq * i / sample_rate))
                arr.append(val & 0xffff)
            
            sound = pygame.sndarray.make_sound(arr)
            sound.set_volume(self.sound_effects_volume)
            sound.play()
        except:
            pass

