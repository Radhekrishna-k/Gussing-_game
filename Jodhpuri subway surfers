# Landmark display
class Landmark:
    def __init__(self):
        self.current = random.choice(JODHPURI_PLACES)
        self.display_time = 0

    def update(self):
        self.display_time -= 1
        if self.display_time <= 0:
            self.current = random.choice(JODHPURI_PLACES)
            self.display_time = 180

    def draw(self, surface, font):
        if self.display_time > 0:
            landmark_text = font.render(f"📍 {self.current['name']}", True, self.current['color'])
            surface.blit(landmark_text, (SCREEN_WIDTH // 2 - 120, 20))

# Game class
class Game:
    def __init__(self, num_players=1):
        self.num_players = num_players
        self.player = Player(player_id=0)  # Main player
        self.obstacles = pygame.sprite.Group()
        self.collectibles = pygame.sprite.Group()
        self.coins = pygame.sprite.Group()
        self.powerups = pygame.sprite.Group()
        self.police = pygame.sprite.Group()
        self.landmark = Landmark()
        
        self.score = 0
        self.coins_collected = 0
        self.high_score = 0
        self.health = 3
        self.game_over = False
        self.spawn_timer = 0
        self.difficulty = 1
        
        self.has_shield = False
        self.has_boost = False
        self.has_magnet = False
        self.shield_time = 0
        self.boost_time = 0
        self.magnet_time = 0
        
        self.font_large = pygame.font.Font(None, 48)
        self.font_medium = pygame.font.Font(None, 36)
        self.font_small = pygame.font.Font(None, 24)
        
        self.police_spawn_timer = 0

    def spawn_obstacle(self):
        x = random.randint(0, SCREEN_WIDTH - 60)
        self.obstacles.add(Obstacle(x, -40))

    def spawn_collectible(self):
        x = random.randint(0, SCREEN_WIDTH - 35)
        self.collectibles.add(Collectible(x, -35))

    def spawn_coin(self):
        x = random.randint(0, SCREEN_WIDTH - 25)
        self.coins.add(Coin(x, -25))

    def spawn_powerup(self):
        x = random.randint(0, SCREEN_WIDTH - 45)
        self.powerups.add(PowerUp(x, -45))

    def spawn_police(self):
        x = random.randint(0, SCREEN_WIDTH - 55)
        self.police.add(Police(x, -50))

    def update(self):
        if not self.game_over:
            self.player.update()
            self.obstacle = self.obstacles.update()
            self.collectibles.update()
            self.coins.update()
            self.powerups.update()
            self.police.update()
            self.landmark.update()

            # Increase difficulty
            self.difficulty = 1 + (self.score // 200) * 0.3

            # Spawn obstacles
            self.spawn_timer += 1
            spawn_rate = max(25, 60 - int(self.difficulty * 8))
            if self.spawn_timer > spawn_rate:
                self.spawn_obstacle()
                self.spawn_timer = 0

            # Spawn collectibles
            if random.randint(1, 100) > 85:
                self.spawn_collectible()

            # Spawn coins (more frequent)
            if random.randint(1, 100) > 80:
                self.spawn_coin()

            # Spawn power-ups
            if random.randint(1, 100) > 96:
                self.spawn_powerup()

            # Spawn police (increases with difficulty)
            self.police_spawn_timer += 1
            police_spawn_rate = max(80, 150 - int(self.difficulty * 10))
            if self.police_spawn_timer > police_spawn_rate and self.score > 100:
                self.spawn_police()
                self.police_spawn_timer = 0

            # Update power-up timers
            if self.has_shield:
                self.shield_time -= 1
                if self.shield_time <= 0:
                    self.has_shield = False
                    self.player.is_protected = False

            if self.has_boost:
                self.boost_time -= 1
                if self.boost_time <= 0:
                    self.has_boost = False
                    self.player.speed = 6

            if self.has_magnet:
                self.magnet_time -= 1
                if self.magnet_time <= 0:
                    self.has_magnet = False

            # Magnet pulls collectibles to player
            if self.has_magnet:
                for collectible in self.collectibles:
                    dx = self.player.rect.centerx - collectible.rect.centerx
                    dy = self.player.rect.centery - collectible.rect.centery
                    distance = (dx**2 + dy**2)**0.5
                    if distance > 0 and distance < 150:
                        collectible.rect.centerx += dx / distance * 5
                        collectible.rect.centery += dy / distance * 5
                
                # Magnet also pulls coins
                for coin in self.coins:
                    dx = self.player.rect.centerx - coin.rect.centerx
                    dy = self.player.rect.centery - coin.rect.centery
                    distance = (dx**2 + dy**2)**0.5
                    if distance > 0 and distance < 150:
                        coin.rect.centerx += dx / distance * 5
                        coin.rect.centery += dy / distance * 5

            # Check collisions with obstacles
            hit_obstacles = pygame.sprite.spritecollide(self.player, self.obstacles, True)
            for obstacle in hit_obstacles:
                audio_manager.play_hit_sound()
                if self.has_shield:
                    self.has_shield = False
                    self.player.is_protected = False
                else:
                    self.health -= 1
                    if self.health <= 0:
                        self.game_over = True
                        self.high_score = max(self.high_score, self.score)

            # Check collisions with collectibles
            for collectible in pygame.sprite.spritecollide(self.player, self.collectibles, True):
                audio_manager.play_coin_sound()
                self.score += collectible.points

            # Check collisions with coins
            for coin in pygame.sprite.spritecollide(self.player, self.coins, True):
                audio_manager.play_coin_sound()
                self.coins_collected += 1
                self.score += 5

            # Check collisions with police
            hit_police = pygame.sprite.spritecollide(self.player, self.police, True)
            for officer in hit_police:
                audio_manager.play_hit_sound()
                if self.has_shield:
                    self.has_shield = False
                    self.player.is_protected = False
                    self.score += 50  # Bonus for escaping police with shield
                else:
                    self.health -= 1
                    if self.health <= 0:
                        self.game_over = True
                        self.high_score = max(self.high_score, self.score)

            # Check collisions with power-ups
            for powerup in pygame.sprite.spritecollide(self.player, self.powerups, True):
                audio_manager.play_powerup_sound()
                if powerup.type == "shield":
                    self.has_shield = True
                    self.shield_time = 300
                    self.player.is_protected = True
                elif powerup.type == "boost":
                    self.has_boost = True
                    self.boost_time = 200
                    self.player.speed = 10
                else:  # magnet
                    self.has_magnet = True
                    self.magnet_time = 250
                    self.score += 30

    def draw(self, surface):
        # Draw gradient sky background
        for y in range(SCREEN_HEIGHT):
            ratio = y / SCREEN_HEIGHT
            color = (
                int(BLUE_CITY[0] + (SKY_BLUE[0] - BLUE_CITY[0]) * ratio),
                int(BLUE_CITY[1] + (SKY_BLUE[1] - BLUE_CITY[1]) * ratio),
                int(BLUE_CITY[2] + (SKY_BLUE[2] - BLUE_CITY[2]) * ratio)
            )
            pygame.draw.line(surface, color, (0, y), (SCREEN_WIDTH, y))

        # Draw buildings
        for i in range(0, SCREEN_WIDTH, 100):
            pygame.draw.rect(surface, LIGHT_BLUE, (i, SCREEN_HEIGHT - 100, 90, 100))
            pygame.draw.rect(surface, BLUE_CITY, (i + 10, SCREEN_HEIGHT - 90, 15, 20))
            pygame.draw.rect(surface, BLUE_CITY, (i + 35, SCREEN_HEIGHT - 90, 15, 20))
            pygame.draw.rect(surface, BLUE_CITY, (i + 60, SCREEN_HEIGHT - 90, 15, 20))

        # Draw game objects
        self.player.draw(surface)
        for obstacle in self.obstacles:
            obstacle.draw(surface)
        for collectible in self.collectibles:
            collectible.draw(surface)
        for coin in self.coins:
            coin.draw(surface)
        for powerup in self.powerups:
            powerup.draw(surface)
        for officer in self.police:
            officer.draw(surface)

        # Draw HUD
        score_text = self.font_medium.render(f"Score: {self.score}", True, GOLD)
        surface.blit(score_text, (10, 10))

        level_text = self.font_small.render(f"Level: {int(self.difficulty)}", True, TURQUOISE)
        surface.blit(level_text, (SCREEN_WIDTH - 200, 10))

        # Health hearts
        health_text = self.font_small.render(f"❤️ {self.health}", True, RED)
        surface.blit(health_text, (10, 50))

        # Coins counter
        coins_text = self.font_small.render(f"💰 {self.coins_collected}", True, GOLD)
        surface.blit(coins_text, (SCREEN_WIDTH - 150, 70))

        # Power-ups status
        powerup_status = ""
        if self.has_shield:
            powerup_status += "🛡️ "
        if self.has_boost:
            powerup_status += "⚡ "
        if self.has_magnet:
            powerup_status += "🧲 "
        
        if powerup_status:
            status_text = self.font_small.render(powerup_status, True, GOLD)
            surface.blit(status_text, (SCREEN_WIDTH - 200, 50))

        # Draw landmark
        self.landmark.draw(surface, self.font_small)
        
        # Music indicator
        music_icon = "🔊" if audio_manager.music_enabled else "🔇"
        music_text = self.font_small.render(f"{music_icon} M:Toggle", True, TURQUOISE)
        surface.blit(music_text, (10, SCREEN_HEIGHT - 30))

        # Game over screen
        if self.game_over:
            # Semi-transparent overlay
            overlay = pygame.Surface((SCREEN_WIDTH, SCREEN_HEIGHT))
            overlay.set_alpha(200)
            overlay.fill(DARK_BLUE)
            surface.blit(overlay, (0, 0))

            game_over_text = self.font_large.render("खेल खत्म!", True, RED)  # "Game Over" in Hindi
            final_score_text = self.font_medium.render(f"अंतिम स्कोर: {self.score}", True, GOLD)
            coins_final_text = self.font_small.render(f"सिक्के: {self.coins_collected}", True, GOLD)
            high_score_text = self.font_medium.render(f"उच्चतम स्कोर: {self.high_score}", True, TURQUOISE)
            restart_text = self.font_small.render("R दबाएँ पुनः शुरू करने के लिए | Q छोड़ने के लिए", True, WHITE)

            surface.blit(game_over_text, (SCREEN_WIDTH // 2 - 200, SCREEN_HEIGHT // 2 - 100))
            surface.blit(final_score_text, (SCREEN_WIDTH // 2 - 220, SCREEN_HEIGHT // 2 - 20))
            surface.blit(coins_final_text, (SCREEN_WIDTH // 2 - 150, SCREEN_HEIGHT // 2 + 10))
            surface.blit(high_score_text, (SCREEN_WIDTH // 2 - 200, SCREEN_HEIGHT // 2 + 50))
            surface.blit(restart_text, (SCREEN_WIDTH // 2 - 280, SCREEN_HEIGHT // 2 + 100))

        pygame.display.flip()

# Main game loop
def main():
    # Start background music
    audio_manager.play_background_music()
    
    game = Game(num_players=1)
    running = True

    # Show welcome screen
    welcome_shown = False
    welcome_timer = 0

    while running:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False
            if event.type == pygame.KEYDOWN:
                if event.key == pygame.K_m:
                    audio_manager.toggle_music()
                if event.key == pygame.K_r and game.game_over:
                    game = Game(num_players=1)
                    welcome_shown = False
                if event.key == pygame.K_q and game.game_over:
                    running = False
                if event.key == pygame.K_SPACE and not welcome_shown:
                    welcome_shown = True

        if not welcome_shown:
            screen.fill(BLUE_CITY)
            title = pygame.font.Font(None, 72).render("जोधपुर रेलवे!", True, GOLD)
            subtitle = pygame.font.Font(None, 36).render("Jodhpuri Subway Surfers", True, TURQUOISE)
            instructions = pygame.font.Font(None, 18).render("सिक्के इकट्ठा करो | पुलिस से बचो | M = संगीत टॉगल करें", True, WHITE)
            start_text = pygame.font.Font(None, 24).render("Press SPACE to Start", True, GOLD)
            
            screen.blit(title, (SCREEN_WIDTH // 2 - 280, SCREEN_HEIGHT // 2 - 120))
            screen.blit(subtitle, (SCREEN_WIDTH // 2 - 200, SCREEN_HEIGHT // 2 - 30))
            screen.blit(instructions, (SCREEN_WIDTH // 2 - 210, SCREEN_HEIGHT // 2 + 30))
            screen.blit(start_text, (SCREEN_WIDTH // 2 - 150, SCREEN_HEIGHT // 2 + 100))
            
            pygame.display.flip()
        else:
            game.update()
            game.draw(screen)

        clock.tick(FPS)

    audio_manager.stop_music()
    pygame.quit()
    sys.exit()

if __name__ == "__main__":
    main()
