# Player class
class Player(pygame.sprite.Sprite):
    def __init__(self, player_id=1):
        super().__init__()
        self.player_id = player_id
        self.image = pygame.Surface((50, 50))
        
        # Different colors for different players
        player_colors = [TURQUOISE, ORANGE, PURPLE]
        player_color = player_colors[player_id % len(player_colors)]
        
        pygame.draw.rect(self.image, player_color, (0, 0, 50, 50))
        pygame.draw.circle(self.image, GOLD, (25, 15), 8)  # Head
        pygame.draw.circle(self.image, BLACK, (20, 13), 3)  # Left eye
        pygame.draw.circle(self.image, BLACK, (30, 13), 3)  # Right eye
        
        self.rect = self.image.get_rect()
        self.rect.centerx = SCREEN_WIDTH // 2
        self.rect.bottom = SCREEN_HEIGHT - 20
        self.speed = 6
        self.is_protected = False
        self.protection_time = 0

    def update(self):
        keys = pygame.key.get_pressed()
        if keys[pygame.K_LEFT] and self.rect.left > 0:
            self.rect.x -= self.speed
        if keys[pygame.K_RIGHT] and self.rect.right < SCREEN_WIDTH:
            self.rect.x += self.speed
        if keys[pygame.K_UP] and self.rect.top > 100:
            self.rect.y -= self.speed
        if keys[pygame.K_DOWN] and self.rect.bottom < SCREEN_HEIGHT - 20:
            self.rect.y += self.speed
        
        # Update protection status
        if self.is_protected:
            self.protection_time -= 1
            if self.protection_time <= 0:
                self.is_protected = False

    def draw(self, surface):
        if self.is_protected:
            pygame.draw.circle(surface, GOLD, self.rect.center, 35, 3)
        surface.blit(self.image, self.rect)

# Coin class - Collectible currency
class Coin(pygame.sprite.Sprite):
    def __init__(self, x, y):
        super().__init__()
        self.image = pygame.Surface((25, 25))
        self.image.fill(GOLD)
        pygame.draw.circle(self.image, ORANGE, (12, 12), 10)
        pygame.draw.line(self.image, ORANGE, (12, 3), (12, 21), 2)
        pygame.draw.line(self.image, ORANGE, (3, 12), (21, 12), 2)
        
        self.rect = self.image.get_rect()
        self.rect.x = x
        self.rect.y = y
        self.speed = 3
        self.rotation = 0

    def update(self):
        self.rect.y += self.speed
        self.rotation += 5
        if self.rect.top > SCREEN_HEIGHT:
            self.kill()

    def draw(self, surface):
        surface.blit(self.image, self.rect)

# Police class - Enemy that chases and blocks
class Police(pygame.sprite.Sprite):
    def __init__(self, x, y):
        super().__init__()
        self.image = pygame.Surface((55, 50))
        self.image.fill(BLACK)  # Police body
        # Draw police car/officer
        pygame.draw.rect(self.image, RED, (10, 5, 35, 20))  # Red siren
        pygame.draw.rect(self.image, WHITE, (5, 20, 45, 25))  # White body
        pygame.draw.circle(self.image, DARK_BLUE, (15, 40), 8)  # Wheels
        pygame.draw.circle(self.image, DARK_BLUE, (40, 40), 8)
        
        self.rect = self.image.get_rect()
        self.rect.x = x
        self.rect.y = y
        self.speed = 5
        self.direction = random.choice([-1, 1])  # Move left or right
        self.change_direction_timer = 0

    def update(self):
        self.rect.y += self.speed
        self.rect.x += self.direction * 2  # Slight sideways movement
        
        # Bounce off edges
        if self.rect.left <= 0 or self.rect.right >= SCREEN_WIDTH:
            self.direction *= -1
        
        if self.rect.top > SCREEN_HEIGHT:
            self.kill()

    def draw(self, surface):
        surface.blit(self.image, self.rect)

